# LaPrincesse — Environment Variables
# Copy this file to .env and fill in your values

# ── Supabase (database + auth) ──────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# To enable Google OAuth:
#   1. Create OAuth credentials at https://console.cloud.google.com
#   2. In Supabase dashboard → Auth → Providers → Google → paste Client ID & Secret
#   3. Add http://localhost:5173 and https://your-domain.com to allowed redirect URLs

# ── Admin access ────────────────────────────────────────────────────
# Comma-separated list of email addresses allowed to view /admin
VITE_ADMIN_EMAILS=admin@laprincesse.com,contact@laprincesse.com
# This env var is server-only (no VITE_ prefix) — safe and not exposed to browser
DEV_USER_EMAIL=dev@laprincesse.com
